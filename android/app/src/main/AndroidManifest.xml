<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required for the foreground IntentRouterService and its restart-on-boot. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- HUN with custom RemoteViews on SDK 33+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Mid-tier escalation reaches the Termux llama.cpp server on localhost only. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Read .jarvisrc + write outbox/jarvis-* in the Syncthing-mounted vault.
         The vault uses MANAGE_DOCUMENTS via SAF, not legacy storage. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.OPEN_DOCUMENT_TREE" />
        </intent>
    </queries>

    <application
        android:name=".JarvisApp"
        android:label="@string/app_name"
        android:theme="@style/Theme.Jarvis"
        android:allowBackup="false"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:supportsRtl="true"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ManualTriggerActivity"
            android:exported="false"
            android:label="@string/manual_trigger_title" />

        <!-- Edit-draft bottom sheet launched by ToastActionReceiver on Edit tap. -->
        <activity
            android:name=".ui.edit.EditActivity"
            android:exported="false"
            android:label="@string/edit_draft_title"
            android:theme="@style/Theme.Jarvis" />

        <!-- Foreground service. specialUse declared per SDK 34 requirements;
             see https://developer.android.com/about/versions/14/changes/fgs-types-required -->
        <service
            android:name=".service.IntentRouterService"
            android:exported="false"
            android:foregroundServiceType="dataSync|specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="On-device intent classifier for personal AI assistant. Runs MobileBERT INT8 via LiteRT; no network egress except Tailscale tailnet." />
        </service>

        <!-- Boot-completed restart. -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Approve/Edit/Dismiss button broadcasts from the toast HUN. -->
        <receiver
            android:name=".ui.notif.ToastActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="dev.jarvis.action.APPROVE" />
                <action android:name="dev.jarvis.action.EDIT" />
                <action android:name="dev.jarvis.action.DISMISS" />
            </intent-filter>
        </receiver>

        <!-- AlarmManager callback that records user_action=timeout if the HUN
             was never acted on within the 30-minute window. -->
        <receiver
            android:name=".ui.notif.TimeoutReceiver"
            android:exported="false" />
    </application>
</manifest>
